generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum EnrollmentStatus {
  ACTIVE
  DROPPED
}

// ================= User =================
model User {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  fullName    String
  age         Int
  phone       String   @unique
  address     String
  role        Role     @default(STUDENT)
  password    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taughtCourses  Course[]     @relation("TeacherCourses")
  enrollments    Enrollment[]
  submissions    Submission[]
  results        Result[]
  refreshTokens  RefreshToken[]

  @@map("users")
}

// ================= RefreshToken =================
model RefreshToken {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ================= Course =================
model Course {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  name        String
  description String
  price       Float
  duration    Int
  teacherId   String   @db.ObjectId
  teacher     User     @relation("TeacherCourses", fields: [teacherId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]
  homeworks   Homework[]
  tests       Test[]

  @@map("courses")
}

// ================= Enrollment =================
model Enrollment {
  id        String           @id @map("_id") @default(auto()) @db.ObjectId
  studentId String           @db.ObjectId
  courseId  String           @db.ObjectId
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("enrollments")
}

// ================= Homework =================
model Homework {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  title       String
  description String
  deadline    DateTime
  courseId    String   @db.ObjectId
  course      Course   @relation(fields: [courseId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]

  @@map("homeworks")
}

// ================= Submission =================
model Submission {
  id         String   @id @map("_id") @default(auto()) @db.ObjectId
  studentId  String   @db.ObjectId
  homeworkId String   @db.ObjectId
  content    String
  fileUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student  User     @relation(fields: [studentId], references: [id])
  homework Homework @relation(fields: [homeworkId], references: [id])

  @@unique([studentId, homeworkId])
  @@map("submissions")
}

// ================= Test =================
model Test {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  title     String
  courseId  String   @db.ObjectId
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions Question[]
  results   Result[]

  @@map("tests")
}

// ================= Question =================
model Question {
  id            String   @id @map("_id") @default(auto()) @db.ObjectId
  testId        String   @db.ObjectId
  text          String
  options       String[]
  correctAnswer String
  createdAt     DateTime @default(now())

  test    Test     @relation(fields: [testId], references: [id])
  answers Answer[]

  @@map("questions")
}

// ================= Answer =================
model Answer {
  id         String   @id @map("_id") @default(auto()) @db.ObjectId
  resultId   String   @db.ObjectId
  questionId String   @db.ObjectId
  answer     String
  isCorrect  Boolean
  createdAt  DateTime @default(now())

  result   Result   @relation(fields: [resultId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@map("answers")
}

// ================= Result =================
model Result {
  id             String   @id @map("_id") @default(auto()) @db.ObjectId
  studentId      String   @db.ObjectId
  testId         String   @db.ObjectId
  totalQuestions Int
  correctCount   Int
  wrongCount     Int
  percentage     Float
  createdAt      DateTime @default(now())

  student User   @relation(fields: [studentId], references: [id])
  test    Test   @relation(fields: [testId], references: [id])
  answers Answer[]

  @@unique([studentId, testId])
  @@map("results")
}